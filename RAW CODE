CREATE OR REPLACE VIEW DASI_PROD_SANDBOX.EXAMPLE_VIEW AS

SELECT 
    CDD.CDD_ID, 
    CDD.TRADING_NAME,
    me.BUSINESS_TYPE,
    me.SUB_TRANCHES,
    me.TRANCHE,
    me.MIGRATION_ELIGIBLE,
    CASE 
        WHEN am.PARTYORGANISATION IS NOT NULL THEN 'Y'
        ELSE 'N'
    END AS PKYC_FLAG,
    CDD.risk_rating, 
    CDD.last_txn_date, 
    CDD.next_review,
    CDD.trigger_event, 
    CDD.managed,
    CDD.BOARDED_DATE,
    '1' AS OPEN_IN_NAP, 
    CONTACTS.PHYSICAL_ADDRESS_STREET AS ADDRESS_LINE_1, 
    CONTACTS.PHYSICAL_ADDRESS_LINE_2, 
    CONTACTS.PHYSICAL_ADDRESS_LINE_3,
    CONTACTS.PHYSICAL_ADDRESS_CITY_LINE,
    CONTACTS.PHYSICAL_ADDRESS_CODE AS ZIPMAILCODEREGISTEREDADDRESS,
    ORG.ORG_REG_AUTH_REF AS Company_Reg_num,
    me.DUP_RP,
    me.DUP_SMB,
    me.DUP_ASSOC,
    me.CONT_INF_BLANK,
    me.BENE_WITH_CONT_INF,
    me.COMP_RPS,
    me.OVER_100,
    me.MCC_PSEUDO,
    me.CYBERSOURCE,
    me.COUNTRY_INCORP,
    me.INVALID_RISK,
    me.HIERACHY_OVER_TWO,
    me.MISSING_CRN,
    me.ORPHAN_ASSOCIATIONS,
    me.REL_SCENARIO_1,
    me.REL_SCENARIO_2,
    me.REL_SCENARIO_3,
    me.REL_SCENARIO_4,
    me.REL_SCENARIO_5,
    me.REL_SCENARIO_6,
    me.REL_SCENARIO_7
FROM 
    DASI_PROD_SANDBOX.REPORTING_DATA.EXAMPLEDATA1 AS CDD //MAIN CUSTOMER MODEL//
JOIN 
    PROD_EU_RADAR_DOMAINS.EXAMPLE2 AS CONTACTS //CUSTOMER CONTACT INFO MODEL//
    ON CDD.CDD_ID = CONTACTS.PARTY_ID
JOIN 
    PROD_CUR_NAP.EXMAPLE3 AS ORG //ORGANISATION INFO MODEL//
    ON CONTACTS.PARTY_ID = ORG.PARTY_ID
JOIN 
    DASI_PROD_SANDBOX.EXAMPLE4 op //ORGANISATION INFO MODEL 2//
    ON op.PARTY_ID = CDD.CDD_ID
JOIN 
    dasi_prod_sandbox.EXAMPLE5 me //EXCEPTIONS INFO MODEL//
    ON me.CDD_ID = CDD.CDD_ID
LEFT JOIN DASI_PROD_SANDBOX.EXAMPLE6 am //MIGRATED INTO FENERGO MODEL//
    ON am.PARTYORGANISATION = CDD.CDD_ID
WHERE 
    CONTACTS.dm_current_flag = 'Y'
    AND CDD.CURRENT_FLAG = 'Y'
   AND CDD.SOURCE_SYSTEM = 'NAP'
   AND REGISTERED_COUNTRY = 'GB'
   AND CONTACTS.address_role_type_id = 'REGISTERED'
   AND CONTACTS.address_type = 'PhysicalAddress'
   AND CONTACTS.VALID_TO IS NULL
   AND CDD.WPUK = 1
   AND CDD.DORMANT = 0
   AND CDD.open_outlet_count > 0
QUALIFY 
    ROW_NUMBER() OVER(PARTITION BY CONTACTS.PARTY_ID ORDER BY CONTACTS.DM_EFFECTIVE_START_DATE DESC) = 1;